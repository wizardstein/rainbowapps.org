SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=     # server-only, never NEXT_PUBLIC
RESEND_API_KEY=                # server-only
OWNER_EMAIL=                   # where new-idea notifications go
RESEND_FROM=idei@rainbowapps.org
CRON_SECRET=                   # openssl rand -hex 32 — guards /api/cron/retry-emails (Vercel Cron sends it as a Bearer token)
NEXT_PUBLIC_SITE_URL=https://www.rainbowapps.org

# Admin (/admin) — Google sign-in, one-person allowlist
AUTH_SECRET=                   # openssl rand -base64 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_EMAIL=                   # the only Google account allowed into /admin

# AI idea refinement (optional /trimite helper)
AI_GATEWAY_API_KEY=            # server-only — Vercel AI Gateway, tried first (free monthly credits)
ANTHROPIC_API_KEY=             # server-only, never NEXT_PUBLIC — fallback when the gateway fails

# Donations — Revolut Merchant API (hosted checkout; card data never touches the site)
REVOLUT_SECRET_KEY=            # server-only
